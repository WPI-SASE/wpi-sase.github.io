---
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';
import ContentSection from '../components/ContentSection.astro';
import { pageContent, site } from '../data/site';

const content = pageContent.home;
---

<Layout title="Home">
    <PageIntro eyebrow={content.eyebrow} title={content.title} intro={content.intro}/>
  {content.sections.map((section) =>
          <ContentSection title={section.title} body={section.body}/>)}

    <section class="container flow-section quick-links-section">
        <div class="simple-list">
          {site.nav.filter((item) => item.href !== '/').map((item) => (
                  <a href={item.href} class="simple-item simple-link-card">
                      <h2>{item.label}</h2>
                  </a>
          ))}
        </div>
    </section>
</Layout>
