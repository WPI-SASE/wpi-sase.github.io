---
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';
import ContentSection from '../components/ContentSection.astro';
import SimpleList from '../components/SimpleList.astro';
import { pageContent, programsTemplate } from '../data/site';

const content = pageContent.programs;
---

<Layout title="Programs">
  <PageIntro eyebrow={content.eyebrow} title={content.title} intro={content.intro} />
  {content.sections.map((section) => <ContentSection title={section.title} body={section.body} />)}
  <SimpleList items={programsTemplate} />
</Layout>
