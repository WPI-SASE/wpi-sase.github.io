---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Member {
  name: string;
  role: string;
  major?: string;
  image?: string;
  bio: string;
}

interface ResolvedMember extends Member {
  resolvedImage: ImageMetadata | null;
}

interface Props {
  members: Member[];
}

const { members = [] } = Astro.props;

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/board/*.{png,jpg,jpeg,webp,avif,gif}',
  { eager: true }
);

const normalizeImagePath = (src?: string) => {
  if (!src) return null;

  const cleaned = src
    .trim()
    .replace(/^\/+/, '')
    .replace(/^src\/assets\//, '')
    .replace(/^assets\//, '');

  return `../assets/${cleaned}`;
};

const resolvedMembers: ResolvedMember[] = members.map((member) => {
  const key = normalizeImagePath(member.image);
  const mod = key ? imageModules[key] : null;

  return {
    ...member,
    resolvedImage: mod?.default ?? null
  };
});
---

<section class="container flow-section">
    <div class="board-grid">
      {resolvedMembers.map((member) => (
              <article class="board-card">
                  <div class="board-image-wrap">
                    {member.resolvedImage ? (
                            <Image
                                    src={member.resolvedImage}
                                    alt={`${member.name} portrait`}
                                    class="board-image"
                                    loading="lazy"
                                    widths={[320, 480, 640]}
                                    sizes="(max-width: 700px) 100vw, (max-width: 1100px) 50vw, 33vw"
                            />
                    ) : (
                            <div class="board-image-fallback" aria-label={`${member.name} placeholder portrait`}>
                                <span>{member.name.charAt(0)}</span>
                            </div>
                    )}
                  </div>

                  <div class="board-copy">
                      <p class="eyebrow small">{member.role}</p>
                      <h2>{member.name}</h2>
                    {member.major && <p class="supporting-text">{member.major}</p>}
                      <p>{member.bio}</p>

                    {!member.resolvedImage && member.image && (
                            <p class="image-note">
                                Missing image: <code>{member.image}</code>
                            </p>
                    )}
                  </div>
              </article>
        ))}
        </div>
        </section>

          <style>
              .board-grid {
                  display: grid;
                  gap: 1.5rem;
                  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
              }

              .board-card {
                  display: flex;
                  flex-direction: column;
                  background: white;
                  border: 1px solid rgba(226, 232, 240, 1);
                  border-radius: 1rem;
                  overflow: hidden;
              }

              .board-image-wrap {
                  width: 100%;
                  aspect-ratio: 1;
                  background: rgba(241, 245, 249, 1);
              }

              .board-image {
                  display: block;
                  width: 100%;
                  height: 100%;
                  object-fit: contain;
              }

              .board-image-fallback {
                  width: 100%;
                  height: 100%;
                  display: grid;
                  place-items: center;
                  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
                  color: #1e3a8a;
                  font-size: 3rem;
                  font-weight: 700;
              }

              .board-copy {
                  padding: 1.25rem;
              }

              .board-copy h2 {
                  margin: 0.2rem 0 0.35rem;
                  font-size: 1.25rem;
              }

              .supporting-text {
                  color: rgba(71, 85, 105, 1);
                  margin-bottom: 0.75rem;
              }

              .eyebrow.small {
                  font-size: 0.78rem;
                  text-transform: uppercase;
                  letter-spacing: 0.08em;
                  color: rgba(37, 99, 235, 1);
                  margin: 0;
              }

              .image-note {
                  margin-top: 0.85rem;
                  font-size: 0.85rem;
                  color: rgba(100, 116, 139, 1);
              }

              .image-note code {
                  font-family: monospace;
              }
          </style>